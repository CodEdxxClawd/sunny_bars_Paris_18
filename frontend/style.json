{
  "version": 8,
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles://https://demo-bucket.protomaps.com/v4.pmtiles",
      "attribution": "© <a href='https://openstreetmap.org'>OpenStreetMap</a> · <a href='https://protomaps.com'>Protomaps</a>"
    },
    "buildings": {
      "type": "geojson",
      "data": "/data/buildings_18e.geojson"
    },
    "shadows": {
      "type": "geojson",
      "data": {"type": "FeatureCollection", "features": []}
    }
  },
  "layers": [
    {"id": "background", "type": "background", "paint": {"background-color": "#f6f1e4"}},
    {"id": "earth", "type": "fill", "source": "protomaps", "source-layer": "earth",
     "paint": {"fill-color": "#f6f1e4"}},
    {"id": "landuse-park", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["in", "kind", "park", "forest", "wood", "grass", "meadow", "nature_reserve", "garden", "recreation_ground", "village_green"],
     "paint": {"fill-color": "#bfe0a8"}},
    {"id": "landuse-pitch", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["in", "kind", "pitch", "playground", "sports_centre"],
     "paint": {"fill-color": "#a8d68c"}},
    {"id": "landuse-cemetery", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["==", "kind", "cemetery"],
     "paint": {"fill-color": "#d4e4c4"}},
    {"id": "landuse-hospital", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["==", "kind", "hospital"],
     "paint": {"fill-color": "#f4dada"}},
    {"id": "landuse-school", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["in", "kind", "school", "university", "college"],
     "paint": {"fill-color": "#ece0c8"}},
    {"id": "landuse-pedestrian", "type": "fill", "source": "protomaps", "source-layer": "landuse",
     "filter": ["in", "kind", "pedestrian", "plaza", "footway"],
     "paint": {"fill-color": "#ede4cc"}},
    {"id": "water", "type": "fill", "source": "protomaps", "source-layer": "water",
     "paint": {"fill-color": "#9fcbe8"}},
    {"id": "roads-minor-casing", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "minor_road", "path"], "minzoom": 14,
     "paint": {"line-color": "#d8cfbb",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 14, 1.2, 18, 8]}},
    {"id": "roads-minor", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "minor_road", "path"], "minzoom": 14,
     "paint": {"line-color": "#ffffff",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 14, 0.6, 18, 6]}},
    {"id": "roads-medium-casing", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["==", "kind", "medium_road"],
     "paint": {"line-color": "#ccbf9c",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 0.8, 18, 14]}},
    {"id": "roads-medium", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["==", "kind", "medium_road"],
     "paint": {"line-color": "#fffdf4",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 0.4, 18, 11]}},
    {"id": "roads-major-casing", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "major_road", "highway"],
     "paint": {"line-color": "#c0b38c",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 8, 1, 18, 20]}},
    {"id": "roads-major", "type": "line", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "major_road", "highway"],
     "paint": {"line-color": "#fff3c8",
       "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 8, 0.6, 18, 16]}},
    {"id": "shadows-fill", "type": "fill", "source": "shadows",
     "paint": {"fill-color": "#1c2230", "fill-opacity": 0.42, "fill-antialias": true}},
    {"id": "buildings-3d", "type": "fill-extrusion", "source": "buildings", "minzoom": 13,
     "paint": {
       "fill-extrusion-color": ["interpolate", ["linear"], ["get", "height"],
         0, "#f0e6d0", 10, "#e4d8bc", 30, "#ccbe9a", 60, "#a8997a"],
       "fill-extrusion-height": ["get", "height"],
       "fill-extrusion-base": 0,
       "fill-extrusion-opacity": 0.94
     }},
    {"id": "places-city", "type": "symbol", "source": "protomaps", "source-layer": "places",
     "filter": ["in", "kind", "locality", "city"], "minzoom": 8,
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Regular"],
       "text-size": ["interpolate", ["linear"], ["zoom"], 8, 12, 14, 16]},
     "paint": {"text-color": "#2b2f38", "text-halo-color": "#f6f1e4", "text-halo-width": 1.4}},
    {"id": "roads-name-major", "type": "symbol", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "major_road", "medium_road", "highway"], "minzoom": 13,
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Regular"],
       "symbol-placement": "line", "text-size": 12, "symbol-spacing": 350,
       "text-max-angle": 30, "text-pitch-alignment": "viewport"},
     "paint": {"text-color": "#3a3226", "text-halo-color": "#ffffff", "text-halo-width": 1.6}},
    {"id": "roads-name-minor", "type": "symbol", "source": "protomaps", "source-layer": "roads",
     "filter": ["in", "kind", "minor_road"], "minzoom": 15,
     "layout": {"text-field": ["get", "name"], "text-font": ["Noto Sans Regular"],
       "symbol-placement": "line", "text-size": 11, "symbol-spacing": 300,
       "text-max-angle": 30, "text-pitch-alignment": "viewport"},
     "paint": {"text-color": "#555042", "text-halo-color": "#ffffff", "text-halo-width": 1.4}}
  ]
}
